# Copia como .env.local y rellena los valores reales.

# ─── Supabase público (Vite lo embebe en el bundle del frontend) ──────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Supabase servidor (solo funciones serverless, nunca va al frontend) ───────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # SECRETO — no compartir

# ─── Resend (solo funciones serverless) ───────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=FRICAL <hola@fricalcalorifugados.com>
CONTACT_TO_EMAIL=info@fricalcalorifugados.com
